# Copy this file to .env and fill in your values.
# When running with Docker Compose, DATABASE_URL is overridden automatically
# by docker-compose.yml — you can leave it as-is or remove it.
# For local development (no Docker), set it to localhost:
DATABASE_URL=postgresql+asyncpg://cogence:cogence@localhost:5432/cogence

# --- Gitea ---
GITEA_URL=https://gitea.example.com
GITEA_TOKEN=your_gitea_token_here
# Comma-separated Gitea organizations to track. Only repos under these orgs are collected.
GITEA_ORGANIZATIONS=myorg,anotherorg
# Set to true to also include personal (user-owned) repos alongside org repos.
GITEA_INCLUDE_PERSONAL=false

# --- API ---
API_SECRET_KEY=change_this_to_a_random_secret

# --- AI / Report generation ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Maximum number of lines per commit diff sent to the LLM (keeps costs predictable).
ATOMIC_COMMIT_THRESHOLD=10
# Language for generated report text. Supported: en, fa
REPORT_LOCALE=en

# --- Logging ---
LOG_LEVEL=INFO
# LOG_FILE=/var/log/cogence/cogence.log

# --- Delivery (scripts/deliver.sh) ---
# Base URL of the Cogence API — no trailing slash.
COGENCE_API_URL=http://localhost:8000
# Bearer token for the deliver script — must match API_SECRET_KEY above.
COGENCE_API_KEY=change_this_to_a_random_secret
# Rocket.Chat incoming webhook URL for daily report delivery.
ROCKETCHAT_WEBHOOK=https://chat.example.com/hooks/xxx/yyy
