# Copy this file to .env and fill in your values.
# When running with Docker Compose, DATABASE_URL is overridden automatically
# by docker-compose.yml — you can leave it as-is or remove it.
# For local development (no Docker), set it to localhost:
DATABASE_URL=postgresql+asyncpg://cogence:cogence@localhost:5432/cogence

GITEA_URL=https://gitea.example.com
GITEA_TOKEN=your_gitea_token_here
API_SECRET_KEY=change_this_to_a_random_secret
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
ATOMIC_COMMIT_THRESHOLD=10
REPORT_LOCALE=en
